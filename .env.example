# LabMate AI - Environment Variables
# Copy this file to .env and fill in your API keys

# Claude API Key (Get from: https://console.anthropic.com)
# PRIMARY AI - Best quality, more sophisticated reasoning
ANTHROPIC_API_KEY=your_claude_api_key_here

# Groq API Key (Get from: https://console.groq.com)
# FALLBACK AI - Very fast and cheap, used if Claude is unavailable
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API Key (Get from: https://console.cloud.google.com)
# FREE tier: 10,000 requests/day
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Port for the API (default: 5000)
PORT=5000

# Optional: Flask environment
FLASK_ENV=development
